# --- Base de datos ---
# Desarrollo con Postgres local (docker compose up -d db):
DATABASE_URL=postgresql+psycopg2://elearning:elearning@localhost:5432/elearning
# Alternativa SQLite (solo desarrollo rápido):
# DATABASE_URL=sqlite:///db-development.sqlite3

# --- App ---
APP_NAME=e-learning
ENVIRONMENT=development            # development | production

# --- JWT ---
JWT_SECRET_KEY=cambia-esto-por-un-secreto-largo-y-aleatorio
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7
REQUIRE_EMAIL_ACTIVATION=false     # true cuando el SMTP esté confiable

# --- Email (activación de cuentas y reset de contraseña) ---
# Opción recomendada: Brevo (gratis 300/día, sin dominio propio).
# 1. Cuenta en brevo.com -> verifica EMAIL_SENDER como remitente
# 2. SMTP & API -> API Keys -> genera una key
BREVO_API_KEY=
EMAIL_SENDER=                 # remitente verificado en Brevo
EMAIL_SENDER_NAME=GoProClass
# Fallback legado (solo si no hay BREVO_API_KEY): Gmail con app password
EMAIL_PASSWORD=

# --- URLs ---
HOST_FRONTEND=http://localhost:3000   # origen permitido en CORS y back_urls de MP
HOST_BACKEND=http://localhost:3005    # links de activación y notification_url de MP
COOKIE_DOMAIN=                        # vacío = cookie host-only (recomendado)

# --- Mercado Pago (Checkout Pro) ---
MERCADOPAGO_ACCESS_TOKEN=             # Access Token de producción o TEST-...
MERCADOPAGO_WEBHOOK_SECRET=           # secreto de firma del panel de webhooks de MP
MERCADOPAGO_CURRENCY_ID=COP           # COP, MXN, ARS, etc.

# --- Stripe (legado, no usado por el flujo actual) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
